    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "postcss": "^8.4.20",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.2.4",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
