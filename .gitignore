# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Override global gitignore (which ignores Python build dirs that collide with our source)
!lib/
!build/

node_modules
# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env*.local

# vercel
.vercel
.playwright-mcp/

# claude code session artifacts + dev audit dumps
.claude/
/site-audit/

# screenshots — ignore loose PNGs everywhere except inside docs/ and public/
*.png
!docs/**/*.png
!public/**/*.png

.compound-engineering/*.local.yaml
.env.local
docs/screenshots/
